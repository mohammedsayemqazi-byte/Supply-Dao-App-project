VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# Optional: only needed in production (e.g. Vercel), where there is no dev proxy.
# Set this to your deployed backend's URL, e.g. https://your-api.onrender.com/api
# Leave unset for local development — it falls back to the Vite proxy at /api.
VITE_API_URL=
